# GlobalOPS · 统一配置
# 平台账号凭证统一管理

# ============ 数据库 ============
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=global_ops
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password_here

# ============ AI API ============
ANTHROPIC_API_KEY=sk-ant-xxxx_your_key_here

# ============ 翻译引擎 ============
DEEPL_API_KEY=your_deepl_api_key_here
OPENAI_API_KEY=sk-xxxx_your_key_here
GOOGLE_TRANSLATE_API_KEY=your_google_api_key_here

# ============ YouTube ============
YOUTUBE_CLIENT_ID=your_client_id.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=your_client_secret
YOUTUBE_REFRESH_TOKEN=your_refresh_token
# Selenium 降级方案（无需 OAuth）
YOUTUBE_COOKIES_FILE=data/youtube_cookies.json

# ============ TikTok ============
TIKTOK_USERNAME=your_tiktok_username
TIKTOK_PASSWORD=your_tiktok_password
TIKTOK_SESSION_FILE=data/tiktok_session.json
TIKTOK_API_KEY=your_tiktok_api_key  # 需官方白名单

# ============ Instagram ============
INSTAGRAM_USERNAME=your_ig_username
INSTAGRAM_PASSWORD=your_ig_password
INSTAGRAM_SESSION_FILE=data/ig_session.json

# ============ Facebook ============
FACEBOOK_EMAIL=your_fb_email
FACEBOOK_PASSWORD=your_fb_password
FACEBOOK_SESSION_FILE=data/fb_session.json

# ============ Pinterest ============
PINTEREST_ACCESS_TOKEN=your_pinterest_token
PINTEREST_BOARD_ID=your_board_id

# ============ 通知渠道 ============
# 飞书
LARK_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/your_webhook_id
LARK_BOT_TOKEN=your_lark_bot_token

# 邮件
SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_USER=h13751019800@163.com
SMTP_PASSWORD=your_163授权码
SMTP_SENDER=GlobalOPS <h13751019800@163.com>

# Slack
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_CHANNEL=#ops-alerts

# ============ 运营配置 ============
# 默认发布地区
DEFAULT_REGION=southeast_asia
DEFAULT_LANG=en

# 视频配置
DEFAULT_DURATION=90
DEFAULT_ASPECT_RATIO=9:16
WATERMARK_TEXT=@manhua_sharing

# 发布时段（UTC）
SCHEDULE_MORNING=08:00
SCHEDULE_NOON=12:00
SCHEDULE_EVENING=19:00
SCHEDULE_NIGHT=20:30

# 收益配置
GOAL_MONTHLY_REVENUE_USD=1000
PAYONEER_EMAIL=your@payoneer.com
PAYPAL_EMAIL=scott365888@gmail.com

# 版权配置
COPYRIGHT_MAX_CLIP_SECONDS=90
COPYRIGHT_STRICT_MODE=false

# 代理（可选）
HTTP_PROXY=
HTTPS_PROXY=
