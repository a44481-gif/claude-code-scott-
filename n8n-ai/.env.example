# ==================== n8n PC電源營銷系統環境變量 ====================
# 複製此文件為 .env 並填入實際值

# ==================== 對外聯絡窗口 (統一使用) ====================
# 獲客窗口
CONTACT_EMAIL=scott365888@gmail.com
WECHAT_ID=PTS9800

# 對外發送郵箱（使用同一郵箱）
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=scott365888@gmail.com
SMTP_PASSWORD=your_gmail_app_password
SMTP_SENDER=Scott <scott365888@gmail.com>

# 團隊郵箱（與對外窗口相同）
SALES_TEAM_EMAIL=scott365888@gmail.com

# ==================== n8n 基本配置 ====================
N8N_USER=admin
N8N_PASSWORD=your_secure_password_here
N8N_HOST=n8n.yourdomain.com
WEBHOOK_URL=https://n8n.yourdomain.com/

# ==================== 時區 ====================
TIMEZONE=Asia/Shanghai

# ==================== PostgreSQL 數據庫 ====================
POSTGRES_DB=psu_marketing
POSTGRES_USER=psu_admin
POSTGRES_PASSWORD=your_postgres_password_here

# ==================== Anthropic AI API ====================
# 請從 https://console.anthropic.com/ 獲取
ANTHROPIC_API_KEY=sk-ant-xxxx_your_key_here

# ==================== 飛書配置 ====================
# 從 https://open.feishu.cn/ 創建機器人獲取
LARK_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/your_webhook_id

# ==================== Slack 配置 ====================
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_TEAM_ID=your_team_id

# ==================== HubSpot CRM ====================
HUBSPOT_API_KEY=your_hubspot_api_key

# ==================== SSL 證書（可選）====================
# 如果使用 Let's Encrypt
# LEKS_EMAIL=admin@yourdomain.com
