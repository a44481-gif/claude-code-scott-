# 豆包运营代理人 - 配置文件
# 请根据您的实际情况修改以下配置

# ===========================================
# 支付宝配置
# ===========================================

# 收款模式: personal(个人) / merchant(商户)
ALIPAY_MODE=personal

# 【商户模式】支付宝应用ID
ALIPAY_APP_ID=

# 【商户模式】应用私钥（RSA2）
ALIPAY_PRIVATE_KEY=

# 【商户模式】支付宝公钥
ALIPAY_PUBLIC_KEY=

# 【商户模式】异步回调地址（必须是公网可访问的地址）
# 示例: https://yourdomain.com/api/alipay-notify
ALIPAY_NOTIFY_URL=

# 【商户模式】同步跳转地址
ALIPAY_RETURN_URL=

# 收款方支付宝账号（个人模式使用）
PERSONAL_ALIPAY_ACCOUNT=

# ===========================================
# 邮件配置
# ===========================================

# SMTP服务器
SMTP_SERVER=smtp.qq.com
SMTP_PORT=465

# 发件人邮箱
SENDER_EMAIL=your-email@qq.com

# 邮箱授权码（不是登录密码）
SENDER_PASSWORD=

# 邮箱加密方式: ssl / tls
SMTP_SSL=true

# ===========================================
# 数据库配置
# ===========================================

# 数据库路径
DB_PATH=./data/orders.db

# ===========================================
# 服务配置
# ===========================================

# 服务器地址
SERVER_HOST=0.0.0.0
SERVER_PORT=5000

# 调试模式
DEBUG=true

# 网站域名（用于生成支付链接）
DOMAIN=http://localhost:5000

# ===========================================
# 通知配置
# ===========================================

# 是否启用邮件通知
ENABLE_EMAIL=true

# 是否启用短信通知
ENABLE_SMS=false

# 管理员邮箱（接收订单通知）
ADMIN_EMAIL=

# ===========================================
# 运营配置
# ===========================================

# 允许的最小支付金额
MIN_AMOUNT=99

# 订单有效期（分钟）
ORDER_EXPIRE_MINUTES=120

# 自动关闭待支付订单（分钟）
AUTO_CANCEL_MINUTES=1440
