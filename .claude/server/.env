# 豆包运营代理人 - 环境配置文件

# ===========================================
# 支付宝配置
# ===========================================

# 收款模式: personal(个人) / merchant(商户)
ALIPAY_MODE=personal

# 【商户模式】支付宝应用ID
ALIPAY_APP_ID=

# 【商户模式】应用私钥（RSA2）
ALIPAY_PRIVATE_KEY=

# 【商户模式】支付宝公钥
ALIPAY_PUBLIC_KEY=

# 【商户模式】异步回调地址（必须是公网地址）
ALIPAY_NOTIFY_URL=https://your-domain.com/api/alipay-notify

# 【商户模式】同步跳转地址
ALIPAY_RETURN_URL=https://your-domain.com/success

# 个人收款账号（手机号或邮箱）
PERSONAL_ALIPAY_ACCOUNT=13751019800

